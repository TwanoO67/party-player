# Party Player - Configuration Docker
# Copiez ce fichier vers .env et ajustez les valeurs selon vos besoins

# Port d'accès à l'application
PORT=8080

# Configuration PHP
PHP_MEMORY_LIMIT=256M
PHP_UPLOAD_MAX_FILESIZE=50M
PHP_POST_MAX_SIZE=50M

# Clés API (à configurer dans config.php)
# YOUTUBE_V3_APIKEY=votre_clé_youtube_ici
# SPOTIFY_CLIENT_ID=votre_client_id_spotify
# SPOTIFY_CLIENT_SECRET=votre_client_secret_spotify
# SPOTIFY_REDIRECT_URI=http://localhost:8080/
